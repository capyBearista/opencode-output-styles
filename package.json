{
  "name": "@capybearista/opencode-output-styles",
  "version": "0.0.0",
  "description": "Output styles plugin for OpenCode",
  "author": "capyBearista <capybearista@gmail.com>",
  "license": "MPL-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "check": "bunx @biomejs/biome check --write .",
    "lint": "bunx @biomejs/biome check .",
    "ci": "bunx @biomejs/biome ci .",
    "test": "bun test"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.14.0"
  },
  "dependencies": {
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@opencode-ai/plugin": ">=1.14.0",
    "@tsconfig/node22": "^22.0.0",
    "@types/bun": "latest",
    "git-cliff": "^2.0.0",
    "husky": "^9.0.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "opencode": "^1.0.0"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "opencode-styles",
    "output-styles"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/capybearista/opencode-output-styles.git"
  }
}
